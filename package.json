{
  "name": "sheet-plus",
  "type": "module",
  "version": "2.11.6",
  "description": "Create Excel-like spreadsheets and easily embed them in Markdown.",
  "author": "ljcoder",
  "license": "Apache-2.0",
  "keywords": [
    "univer",
    "obsidian",
    "excel",
    "spreadsheet"
  ],
  "engines": {
    "node": ">=20 || <=22",
    "pnpm": ">=8"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "vite build --mode development",
    "build": "vite build",
    "release": "release-it",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "patch-local": "node scripts/patch-local.js"
  },
  "dependencies": {
    "@ljcoder/authorization": "workspace:*",
    "@ljcoder/charts": "workspace:*",
    "@ljcoder/embed-link-ui": "workspace:*",
    "@ljcoder/import-export": "workspace:*",
    "@ljcoder/save": "workspace:*",
    "@ljcoder/sheets-outgoing-link": "workspace:*",
    "@ljcoder/sheets-outgoing-link-ui": "workspace:*",
    "@ljcoder/smart-sheet": "workspace:*",
    "@univerjs/core": "catalog:",
    "@univerjs/data-validation": "catalog:",
    "@univerjs/design": "catalog:",
    "@univerjs/docs": "catalog:",
    "@univerjs/docs-drawing": "catalog:",
    "@univerjs/docs-ui": "catalog:",
    "@univerjs/drawing": "catalog:",
    "@univerjs/drawing-ui": "catalog:",
    "@univerjs/engine-formula": "catalog:",
    "@univerjs/engine-render": "catalog:",
    "@univerjs/find-replace": "catalog:",
    "@univerjs/protocol": "catalog:",
    "@univerjs/sheets": "catalog:",
    "@univerjs/sheets-conditional-formatting": "catalog:",
    "@univerjs/sheets-conditional-formatting-ui": "catalog:",
    "@univerjs/sheets-crosshair-highlight": "catalog:",
    "@univerjs/sheets-data-validation": "catalog:",
    "@univerjs/sheets-data-validation-ui": "catalog:",
    "@univerjs/sheets-drawing": "catalog:",
    "@univerjs/sheets-drawing-ui": "catalog:",
    "@univerjs/sheets-filter": "catalog:",
    "@univerjs/sheets-filter-ui": "catalog:",
    "@univerjs/sheets-find-replace": "catalog:",
    "@univerjs/sheets-formula": "catalog:",
    "@univerjs/sheets-formula-ui": "catalog:",
    "@univerjs/sheets-hyper-link": "catalog:",
    "@univerjs/sheets-hyper-link-ui": "catalog:",
    "@univerjs/sheets-note": "catalog:",
    "@univerjs/sheets-note-ui": "catalog:",
    "@univerjs/sheets-numfmt": "catalog:",
    "@univerjs/sheets-numfmt-ui": "catalog:",
    "@univerjs/sheets-sort": "catalog:",
    "@univerjs/sheets-sort-ui": "catalog:",
    "@univerjs/sheets-table": "catalog:",
    "@univerjs/sheets-table-ui": "catalog:",
    "@univerjs/sheets-thread-comment": "catalog:",
    "@univerjs/sheets-thread-comment-ui": "catalog:",
    "@univerjs/sheets-ui": "catalog:",
    "@univerjs/sheets-zen-editor": "catalog:",
    "@univerjs/themes": "catalog:",
    "@univerjs/thread-comment": "catalog:",
    "@univerjs/thread-comment-ui": "catalog:",
    "@univerjs/ui": "catalog:",
    "antd": "catalog:",
    "antd-style": "3.7.1",
    "monkey-around": "3.0.0",
    "process": "0.11.10"
  },
  "devDependencies": {
    "@antfu/eslint-config": "2.27.3",
    "@release-it/conventional-changelog": "8.0.2",
    "@univerjs/vite-plugin": "catalog:",
    "eslint": "8.57.1",
    "obsidian": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "release-it": "17.10.0",
    "rxjs": "catalog:",
    "simple-git-hooks": "2.11.1",
    "vite": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "eslint --fix --cache && git add -u"
  }
}
